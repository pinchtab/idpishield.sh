---
import { cn } from '@/lib/utils';

export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class={cn(
    'rounded-md border border-[rgb(var(--brand-border-subtle-rgb)/0.10)]',
    'bg-brand-surface p-6',
    'transition-colors duration-200 hover:bg-brand-surface-hover',
    className
  )}
>
  <slot />
</div>
