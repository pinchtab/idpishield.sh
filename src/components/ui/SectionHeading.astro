---
import { cn } from '@/lib/utils';

export interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  class?: string;
}

const { label, title, subtitle, class: className } = Astro.props;
---

<div class={cn('text-center mb-12', className)}>
  {label && <p class="section-label mb-3">{label}</p>}
  <h2 class="mb-4">{title}</h2>
  {subtitle && (
    <p class="text-lg text-brand-text-muted max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
