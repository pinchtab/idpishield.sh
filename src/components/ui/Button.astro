---
import { cn } from '@/lib/utils';

export interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}

const { href, variant = 'primary', size = 'md', class: className, ...rest } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-semibold transition-all duration-200 cursor-pointer';

const variants = {
  primary: 'bg-[rgb(var(--brand-accent-rgb))] text-[rgb(var(--brand-accent-contrast-rgb))] hover:brightness-110',
  secondary: 'border border-[rgb(var(--brand-border-subtle-rgb)/0.20)] text-brand-text bg-transparent hover:bg-[rgba(255,255,255,0.05)]',
};

const sizes = {
  sm: 'h-9 px-4 text-sm rounded-lg',
  md: 'h-11 px-6 text-sm rounded-[10px]',
  lg: 'h-13 px-8 text-base rounded-[10px]',
};

const classes = cn(baseClasses, variants[variant], sizes[size], className);
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button class={classes} {...rest}>
    <slot />
  </button>
)}
