---
import Footer from './Footer.astro';
import '@/styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title = 'idpi-shield — Indirect Prompt Injection Defense',
  description = 'Fast, local defense against indirect prompt injection attacks. Go library, CLI, and MCP server. Sub-millisecond detection, 88+ patterns, zero external dependencies.',
  canonical,
  ogImage = '/og-image.png',
  ogType = 'website',
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : Astro.url.origin;
const canonicalUrl = canonical ? new URL(canonical, siteUrl).toString() : new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'idpi-shield',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  description: 'Defense against Indirect Prompt Injection (IDPI) attacks for AI agents and LLM applications.',
  url: siteUrl,
  downloadUrl: 'https://github.com/pinchtab/idpishield/releases/latest',
  softwareVersion: 'latest',
  license: 'https://opensource.org/licenses/Apache-2.0',
  programmingLanguage: 'Go',
  author: {
    '@type': 'Person',
    name: 'Luigi Agosti',
    url: 'https://github.com/luigi-agosti',
  },
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Luigi Agosti" />
    <meta
      name="keywords"
      content="prompt injection, IDPI, indirect prompt injection, AI security, LLM defense, Go library, MCP server, AI agent safety, content filtering"
    />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="idpi-shield" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon.png" />
    <meta name="theme-color" content="#10b981" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
