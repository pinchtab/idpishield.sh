---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import CodeBlock from '@/components/ui/CodeBlock.astro';
---

<section>
  <SectionHeading
    label="Output"
    title="Structured risk results"
    subtitle="Every assessment returns an actionable, auditable result."
  />

  <div class="grid gap-6 md:grid-cols-2 items-start">
    <div>
      <CodeBlock title="result.go" lang="go">{`type RiskResult struct {
    Score      int      // 0–100 risk estimate
    Level      string   // safe | low | medium | high | critical
    Blocked    bool     // policy decision (score + strict mode)
    Reason     string   // human-readable explanation
    Patterns   []string // matched pattern IDs
    Categories []string // threat categories
}`}</CodeBlock>
    </div>

    <div class="space-y-4">
      <div class="rounded-md border border-[rgb(var(--brand-border-subtle-rgb)/0.10)] bg-brand-surface p-5">
        <h3 class="text-sm font-semibold text-brand-text mb-3">Risk Levels</h3>
        <div class="space-y-2 text-sm">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-[rgb(34_197_94)]"></span>
            <span class="text-brand-text-muted"><strong class="text-brand-text">safe</strong> — score 0–19</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-[rgb(34_197_94/0.6)]"></span>
            <span class="text-brand-text-muted"><strong class="text-brand-text">low</strong> — score 20–39</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-[rgb(245_158_11)]"></span>
            <span class="text-brand-text-muted"><strong class="text-brand-text">medium</strong> — score 40–59</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-[rgb(239_68_68)]"></span>
            <span class="text-brand-text-muted"><strong class="text-brand-text">high</strong> — score 60–79</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-[rgb(239_68_68)]"></span>
            <span class="text-brand-text-muted"><strong class="text-brand-text">critical</strong> — score 80–100</span>
          </div>
        </div>
      </div>

      <div class="rounded-md border border-[rgb(var(--brand-border-subtle-rgb)/0.10)] bg-brand-surface p-5">
        <h3 class="text-sm font-semibold text-brand-text mb-2">Blocking Semantics</h3>
        <p class="text-sm text-brand-text-muted">
          Default mode blocks at score <code>≥ 60</code>. Strict mode lowers the threshold to <code>≥ 40</code>.
          The <code>blocked</code> field is a policy output, not just a detection flag.
        </p>
      </div>
    </div>
  </div>
</section>
