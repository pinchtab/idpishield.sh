---
import Button from '@/components/ui/Button.astro';
import Pill from '@/components/ui/Pill.astro';
import { cn } from '@/lib/utils';

const featurePills = ['Go', 'Sub-millisecond', 'Apache 2.0', '88+ patterns', 'MCP server'];
---

<section
  class={cn(
    'relative isolate flex items-center justify-center',
    'pt-20 pb-15 px-6 sm:px-8 overflow-hidden'
  )}
>
  <!-- Top radial glow -->
  <div
    class={cn(
      'pointer-events-none absolute left-1/2 z-0',
      'h-215 w-215 -translate-x-1/2 rounded-full'
    )}
    style="top: -300px; background: radial-gradient(circle, rgb(var(--brand-accent-rgb) / 0.12) 0%, rgb(var(--brand-accent-rgb) / 0.05) 42%, transparent 72%);"
    aria-hidden="true"
  />

  <div class="relative z-10 max-w-4xl mx-auto pt-12 text-center">
    <!-- Shield icon -->
    <div class="relative z-10 mb-6 flex justify-center">
      <div class="relative w-28 h-28 sm:w-32 sm:h-32 flex items-center justify-center">
        <svg viewBox="0 0 100 100" class="w-full h-full drop-shadow-[0_0_30px_rgb(var(--brand-accent-rgb)/0.3)]" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M50 8L14 26v24c0 22.4 15.4 43.3 36 48 20.6-4.7 36-25.6 36-48V26L50 8z"
            fill="rgb(var(--brand-accent-rgb) / 0.08)"
            stroke="rgb(var(--brand-accent-rgb))"
            stroke-width="2"
          />
          <path
            d="M50 8L14 26v24c0 22.4 15.4 43.3 36 48V8z"
            fill="rgb(var(--brand-accent-rgb) / 0.15)"
          />
          <path
            d="M42 50l8 8 16-16"
            stroke="rgb(var(--brand-accent-light-rgb))"
            stroke-width="4"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </div>
    </div>

    <!-- Brand name -->
    <h1
      class={cn(
        'relative z-20',
        'font-bold leading-[1.1] tracking-[-0.03em]',
        'text-[clamp(2.8rem,6vw,4.2rem)]',
        'mb-2'
      )}
    >
      <span class="gradient-text inline-block">idpishield</span>
    </h1>

    <!-- Tagline -->
    <div class="mb-5 text-base font-medium uppercase tracking-[0.15em] text-brand-accent">
      Defense against indirect prompt injection
    </div>

    <!-- Description -->
    <p class={cn(
      'text-[1.15rem] text-brand-text-muted leading-[1.7]',
      'max-w-130 mx-auto mb-8'
    )}>
      Fast, local risk assessment for untrusted text before it reaches your LLM.
      Go library, CLI, and MCP server. Sub-millisecond detection with 88+ patterns.
    </p>

    <!-- Feature pills -->
    <div class="mb-9 flex flex-wrap items-center justify-center gap-2.5">
      {featurePills.map((pill) => <Pill>{pill}</Pill>)}
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3.5">
      <Button
        href="https://github.com/pinchtab/idpishield"
        variant="primary"
        size="md"
        class={cn(
          'w-full sm:w-auto h-12 px-7 rounded-[10px]',
          'shadow-[0_8px_18px_rgb(var(--brand-accent-rgb)/0.22)]',
          'hover:-translate-y-px hover:shadow-[0_12px_24px_rgb(var(--brand-accent-rgb)/0.28)]',
          'active:translate-y-0 text-[0.9rem]'
        )}
      >
        View on GitHub
      </Button>
      <Button
        href="/docs"
        variant="secondary"
        size="md"
        class={cn(
          'w-full sm:w-auto h-12 px-7 rounded-[10px]',
          'shadow-[inset_0_1px_0_rgb(255_255_255/0.03)]',
          'hover:bg-[rgba(255,255,255,0.08)] hover:border-[rgb(var(--brand-border-subtle-rgb)/0.34)] hover:-translate-y-px',
          'text-[0.9rem]'
        )}
      >
        Docs
      </Button>
    </div>
  </div>
</section>
